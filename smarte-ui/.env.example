# SMARTe API Key (server-side only — never expose to client)
SMARTE_API_KEY=your_smarte_api_key_here

# Anthropic API Key — for Claude-powered natural language interface
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override SMARTe base URL
SMARTE_BASE_URL=https://api.smarte.pro/v7

# Next.js public URL (used for multi-org redirect)
NEXTAUTH_URL=http://localhost:3000

# App environment
NODE_ENV=development
